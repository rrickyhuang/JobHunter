# Copy to .env and fill in. .env is gitignored.

# Anthropic API key for LLM enrichment (Claude Haiku).
ANTHROPIC_API_KEY=sk-ant-...

# Gmail delivery. Use a Google "App Password" (requires 2FA on the account),
# NOT your normal Gmail password. Generate at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# Where the digest gets emailed (defaults to GMAIL_ADDRESS if unset).
DIGEST_TO=you@gmail.com

# Optional: Google Maps Distance Matrix API key, for real transit-time
# refinement of digest-shortlist jobs only (commute.google_maps.enabled in
# config.yaml). Everything else works fine without this set.
GOOGLE_MAPS_API_KEY=
